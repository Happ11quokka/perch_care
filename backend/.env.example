# Database
DATABASE_URL=postgresql+asyncpg://perchcare:perchcare@localhost:5432/perchcare

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# File upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# OpenAI
OPENAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Embedding
EMBEDDING_MODEL=text-embedding-3-large

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=perch-care

# Apple IAP (App Store Server API v2)
APPLE_KEY_ID=
APPLE_ISSUER_ID=
APPLE_PRIVATE_KEY=
APPLE_BUNDLE_ID=com.perch.perchCare2

# Google IAP
GOOGLE_PACKAGE_NAME=com.perchcare.app
GOOGLE_SERVICE_ACCOUNT_JSON=

# Server
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["*"]
